<Window x:Class="ExchangeOffice.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Currency Exchange Office" Height="500" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Currency Exchange Office" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="1" Header="Check Exchange Rate" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Currency Code:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtCurrencyCode" Width="80" Margin="0,0,5,0"/>
                <Button Content="Get Rate" Click="GetRate_Click" Padding="10,3"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Calculate Exchange" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtFromCurrency" Width="60" Margin="0,0,5,0"/>
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtToCurrency" Width="60" Margin="0,0,5,0"/>
                <TextBlock Text="Amount:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtAmount" Width="80" Margin="0,0,5,0"/>
                <Button Content="Calculate" Click="Calculate_Click" Padding="10,3"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Results">
            <TextBox x:Name="txtResults" IsReadOnly="True" 
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Margin="5"/>
        </GroupBox>
    </Grid>
</Window>